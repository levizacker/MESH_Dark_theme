{
  "manifest_version": 3,
  "name": "MDT",
  "version": "v1.2",
  "description": "тёмная тема для сайта МЭШ на ПК",
  "author": "levizack",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["*://school.mos.ru/*", "*://uchebnik.mos.ru/*", "*://mos.ru/*", "*://*.mos.ru/*", "*://login.mos.ru/*", "*://authedu.mosreg.ru/*" ],
  "action": {
    "default_icon": {
      "16":"icon16.png",
      "24":"icon24.png",
      "32":"icon32.png",
      "48":"icon48.png",
      "64":"icon64.png"
    },
    "default_title":"MDT",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://school.mos.ru/*", "*://uchebnik.mos.ru/*"],
      "js": ["script.js"],
      "css": ["table.css"],
      "run_at": "document_start"
    }
  ]
}
